NODE_ENV=development
PORT=3000
API_VERSION=v1

DATABASE_URL=postgresql://heyauto:heyauto123@localhost:5432/heyauto
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=your-access-secret-min-16-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-16-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

OTP_EXPIRY_SEC=300
DRIVER_SEARCH_RADIUS_KM=3
RIDE_REQUEST_TIMEOUT_SEC=15
MAX_MATCHING_ROUNDS=3

# Google Maps — https://console.cloud.google.com/apis/credentials
# Enable: Directions API, Places API, Geocoding API, Distance Matrix API
GOOGLE_MAPS_API_KEY=

# Optional: Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional: Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Optional: Firebase (push notifications)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
